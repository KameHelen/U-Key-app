<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#0D0D15">

    <!-- PANEL IZQUIERDO: Categorías fijas -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:minWidth="280dp"
        android:orientation="vertical"
        android:background="#0A0815"
        android:padding="16dp">

        <!-- Logo -->
        <ImageView
            android:id="@+id/imageViewLogo"
            android:layout_width="140dp"
            android:layout_height="72dp"
            android:src="@drawable/logo_ukey"
            android:contentDescription="Logo U-KEY"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Hero (compacto en landscape) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:background="#13102A"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="U-Key"
                android:textColor="#F0EAF8"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accesorios Gaming"
                android:textColor="#7A6E94"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:gravity="center" />

        </LinearLayout>

        <!-- SECCIÓN CATEGORÍAS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Categorías"
            android:textColor="#F0EAF8"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:layout_marginBottom="14dp" />

        <!-- TARJETAS CATEGORÍAS (en vertical) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:weightSum="3">

            <!-- Teclados -->
            <LinearLayout
                android:id="@+id/categoryTeclados"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_background"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⌨️"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Teclados"
                    android:textColor="#C084E8"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

            <!-- Ratones -->
            <LinearLayout
                android:id="@+id/categoryRatones"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_background"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🖱️"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ratones"
                    android:textColor="#C084E8"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

            <!-- Accesorios -->
            <LinearLayout
                android:id="@+id/categoryAccesorios"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_background"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎮"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Accesorios"
                    android:textColor="#C084E8"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Footer fijo en el panel izquierdo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="© 2026 U-Key"
            android:textColor="#4A3F62"
            android:textSize="10sp"
            android:letterSpacing="0.02"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_marginTop="16dp" />

    </LinearLayout>

    <!-- PANEL DERECHO: Contenido dinámico (productos) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2"
        android:orientation="vertical"
        android:background="#0D0D15"
        android:padding="16dp">

        <!-- Header superior (carrito, salir) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:paddingBottom="16dp">

            <ImageButton
                android:id="@+id/btnCarrito"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_cart"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Ir al carrito"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btnCerrarSesion"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Salir"
                android:textSize="12sp"
                android:textColor="#C084E8"
                android:backgroundTint="#1E1433"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <!-- Contenedor dinámico (aquí se cargan los fragments de productos) -->
        <FrameLayout
            android:id="@+id/fragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

</LinearLayout>