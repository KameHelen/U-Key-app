<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LoginLayout">

        <!-- MainActivity: pantalla de inicio (launcher) -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.LoginLayout">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- RegisterActivity: pantalla de registro -->
        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.LoginLayout" />

        <!-- CarritoActivity: pantalla del carrito de compra -->
        <activity
            android:name=".CarritoActivity"
            android:exported="false"
            android:label="Carrito"
            android:theme="@style/Theme.LoginLayout" />

        <!-- HomeActivity: pantalla principal tras el login -->
        <activity
            android:name=".HomeActivity"
            android:exported="false"
            android:theme="@style/Theme.LoginLayout" />

        <activity
            android:name=".CategoriasActivity"
            android:exported="false" />

    </application>

</manifest>