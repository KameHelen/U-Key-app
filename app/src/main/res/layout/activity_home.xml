<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D15">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER / NAVBAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:layout_marginTop="16dp"
            android:background="#0A0815">

            <ImageView
                android:id="@+id/imageViewLogo"
                android:layout_width="140dp"
                android:layout_height="72dp"
                android:src="@drawable/logo_ukey"
                android:contentDescription="Logo U-KEY" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Botón Carrito -->
            <ImageButton
                android:id="@+id/btnCarrito"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_cart"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Ir al carrito"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnCerrarSesion"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Salir"
                android:textSize="12sp"
                android:textColor="#C084E8"
                android:backgroundTint="#1E1433"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <!-- HERO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="52dp"
            android:paddingBottom="52dp"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:background="#13102A">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tu tienda de accesorios gaming"
                android:textColor="#F0EAF8"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.01"
                android:gravity="center"
                android:maxLines="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Teclados mecánicos, ratones y más"
                android:textColor="#7A6E94"
                android:textSize="14sp"
                android:letterSpacing="0.02"
                android:layout_marginTop="10dp"
                android:gravity="center" />

        </LinearLayout>

        <!-- SECCIÓN CATEGORÍAS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Categorías"
            android:textColor="#F0EAF8"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:layout_marginStart="24dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="14dp" />

        <!-- TARJETAS CATEGORÍAS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:weightSum="3">

            <!-- Teclados -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_background">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⌨️"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Teclados"
                    android:textColor="#C084E8"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

            <!-- Ratones -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_background">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🖱️"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ratones"
                    android:textColor="#C084E8"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

            <!-- Accesorios -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_background">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎮"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Accesorios"
                    android:textColor="#C084E8"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- SECCIÓN PRODUCTOS DESTACADOS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Productos destacados"
            android:textColor="#F0EAF8"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:layout_marginStart="24dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="14dp" />

        <!-- TARJETA PRODUCTO 1 -->
        <LinearLayout
            android:id="@+id/cardProducto1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/card_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ivProducto1"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_producto_placeholder"
                    android:scaleType="centerCrop"
                    android:contentDescription="Imagen producto 1" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvNombreProducto1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Teclado Mecánico Pro"
                        android:textColor="#F0EAF8"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDescProducto1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Switches Cherry MX · RGB"
                        android:textColor="#7A6E94"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:id="@+id/tvPrecioProducto1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="89.99 €"
                        android:textColor="#C084E8"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />

                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnAnadirProducto1"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Añadir al carrito"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/btn_neon_purple"
                android:layout_marginTop="14dp"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <!-- TARJETA PRODUCTO 2 -->
        <LinearLayout
            android:id="@+id/cardProducto2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/card_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ivProducto2"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_producto_placeholder"
                    android:scaleType="centerCrop"
                    android:contentDescription="Imagen producto 2" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvNombreProducto2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ratón Gaming RGB"
                        android:textColor="#F0EAF8"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDescProducto2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="16000 DPI · 7 botones"
                        android:textColor="#7A6E94"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:id="@+id/tvPrecioProducto2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="49.99 €"
                        android:textColor="#C084E8"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />

                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnAnadirProducto2"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Añadir al carrito"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/btn_neon_purple"
                android:layout_marginTop="14dp"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <!-- FOOTER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="© 2026 U-Key"
            android:textColor="#4A3F62"
            android:textSize="11sp"
            android:letterSpacing="0.02"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="28dp" />

    </LinearLayout>

</ScrollView>